{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "next-meeting",
  "title": "Next Meeting",
  "description": "See your next calendar meeting and time until it starts",
  "icon": "extension-icon.png",
  "author": "MaximeLaplace",
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "next-meeting",
      "title": "Next Meeting",
      "description": "Show your next calendar meeting",
      "mode": "view",
      "icon": "command-icon.png"
    },
{
      "name": "refresh-cache",
      "title": "Refresh Calendar Cache",
      "description": "Background refresh of calendar data",
      "mode": "no-view",
      "interval": "10m"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.0",
    "@raycast/utils": "^1.19.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.9",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
